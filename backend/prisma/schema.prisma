generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  SUPER_ADMIN
  INSTITUTE_ADMIN
  TEACHER
  ACCOUNTANT
  STAFF
  PARENT
  STUDENT
}

enum PermissionEffect {
  ALLOW
  DENY
}

enum InstitutionStatus {
  ACTIVE
  SUSPENDED
  MAINTENANCE
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  OVERDUE
  SUSPENDED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum InquiryStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  CLOSED
}

enum InquiryPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CRMActivityType {
  NOTE
  EMAIL
  CALL
  MEETING
  FOLLOW_UP
  STATUS_CHANGE
}

enum NoticeSeverity {
  INFO
  SUCCESS
  WARNING
  CRITICAL
}

model Institution {
  id                       Int                       @id @default(autoincrement())
  name                     String
  code                     String                    @unique @db.VarChar(30)
  tenantKey                String                    @unique @db.VarChar(60)
  subdomain                String                    @unique @db.VarChar(100)
  customDomain             String?                   @unique @db.VarChar(190)
  officialEmail            String?                   @db.VarChar(190)
  billingEmail             String?                   @db.VarChar(190)
  primaryPhone             String?                   @db.VarChar(40)
  secondaryPhone           String?                   @db.VarChar(40)
  contactPersonName        String?                   @db.VarChar(120)
  contactPersonTitle       String?                   @db.VarChar(100)
  address                  String?                   @db.Text
  city                     String?                   @db.VarChar(100)
  country                  String                    @default("Pakistan") @db.VarChar(100)
  status                   InstitutionStatus         @default(ACTIVE)
  activatedAt              DateTime?
  suspendedAt              DateTime?
  suspensionReason         String?                   @db.Text
  users                    User[]
  subscriptions            Subscription[]
  invoices                 SaaSInvoice[]
  notices                  GlobalNoticeRecipient[]
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  studentSeq               Int                       @default(0)
  students                 Student[]
  attendanceSessions       AttendanceSession[]
  studentAttendance        StudentAttendance[]
  staffAttendances         StaffAttendance[]
  examBoardSchemes         ExamBoardScheme[]
  examSchemeSubjects       ExamSchemeSubject[]
  examElectiveGroups       ExamElectiveGroup[]
  examElectiveOptions      ExamElectiveOption[]
  studentSubjectSelections StudentSubjectSelection[]
  examDefinitions          ExamDefinition[]
  examSubjectPapers        ExamSubjectPaper[]
  examMarksEntries         ExamMarksEntry[]
  examResults              ExamResult[]
  examResultSubjects       ExamResultSubject[]

  @@index([status])
  @@index([name])
}

model User {
  id                  Int               @id @default(autoincrement())
  institutionId       Int?
  name                String            @db.VarChar(120)
  username            String            @unique @db.VarChar(100)
  email               String?           @unique @db.VarChar(190)
  passwordHash        String
  role                PlatformRole
  isActive            Boolean           @default(true)
  lastLoginAt         DateTime?
  institution         Institution?      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  permissionOverrides UserPermission[]
  staffAttendances    StaffAttendance[]

  @@index([institutionId, role])
  @@index([isActive])
}

model SubscriptionPlan {
  id            Int            @id @default(autoincrement())
  name          String         @unique @db.VarChar(100)
  billingCycle  BillingCycle
  basePrice     Decimal        @db.Decimal(12, 2)
  currency      String         @default("PKR") @db.VarChar(10)
  maxStudents   Int?
  maxUsers      Int?
  isActive      Boolean        @default(true)
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Subscription {
  id                Int                @id @default(autoincrement())
  institutionId     Int
  planId            Int
  status            SubscriptionStatus @default(TRIAL)
  startDate         DateTime
  nextBillingDate   DateTime
  endDate           DateTime?
  customPrice       Decimal?           @db.Decimal(12, 2)
  concessionAmount  Decimal            @default(0) @db.Decimal(12, 2)
  concessionPercent Decimal            @default(0) @db.Decimal(5, 2)
  autoSuspend       Boolean            @default(true)
  graceDays         Int                @default(7)
  institution       Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  plan              SubscriptionPlan   @relation(fields: [planId], references: [id])
  invoices          SaaSInvoice[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([institutionId, status])
  @@index([nextBillingDate])
}

model SaaSInvoice {
  id               Int           @id @default(autoincrement())
  institutionId    Int
  subscriptionId   Int?
  invoiceNo        String        @unique @db.VarChar(50)
  issueDate        DateTime
  dueDate          DateTime
  subtotal         Decimal       @db.Decimal(12, 2)
  concessionAmount Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount        Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount      Decimal       @db.Decimal(12, 2)
  paidAmount       Decimal       @default(0) @db.Decimal(12, 2)
  status           InvoiceStatus @default(PENDING)
  notes            String?       @db.Text
  institution      Institution   @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payments         SaaSPayment[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([institutionId, status])
  @@index([dueDate, status])
}

model SaaSPayment {
  id          Int         @id @default(autoincrement())
  invoiceId   Int
  amount      Decimal     @db.Decimal(12, 2)
  paymentDate DateTime
  method      String      @db.VarChar(50)
  referenceNo String?     @db.VarChar(100)
  receivedBy  String?     @db.VarChar(120)
  notes       String?     @db.Text
  invoice     SaaSInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())

  @@index([invoiceId, paymentDate])
}

model ClientInquiry {
  id                     Int             @id @default(autoincrement())
  institutionName        String          @db.VarChar(190)
  institutionType        String?         @db.VarChar(80)
  contactName            String          @db.VarChar(120)
  designation            String?         @db.VarChar(100)
  email                  String?         @db.VarChar(190)
  phone                  String?         @db.VarChar(40)
  alternatePhone         String?         @db.VarChar(40)
  city                   String?         @db.VarChar(100)
  address                String?         @db.Text
  website                String?         @db.VarChar(190)
  expectedStudents       Int?
  message                String?         @db.Text
  source                 String?         @db.VarChar(100)
  priority               InquiryPriority @default(MEDIUM)
  status                 InquiryStatus   @default(NEW)
  assignedTo             String?         @db.VarChar(120)
  followUpAt             DateTime?
  convertedAt            DateTime?
  convertedInstitutionId Int?
  activities             CRMActivity[]
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  @@index([status, createdAt])
  @@index([priority, followUpAt])
  @@index([email])
  @@index([phone])
}

model CRMActivity {
  id          Int             @id @default(autoincrement())
  inquiryId   Int
  type        CRMActivityType @default(NOTE)
  subject     String?         @db.VarChar(190)
  details     String          @db.Text
  performedBy String?         @db.VarChar(120)
  activityAt  DateTime        @default(now())
  inquiry     ClientInquiry   @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())

  @@index([inquiryId, activityAt])
}

model GlobalNotice {
  id          Int                     @id @default(autoincrement())
  title       String                  @db.VarChar(190)
  message     String                  @db.Text
  severity    NoticeSeverity          @default(INFO)
  publishAt   DateTime                @default(now())
  expiresAt   DateTime?
  isBroadcast Boolean                 @default(true)
  recipients  GlobalNoticeRecipient[]
  createdAt   DateTime                @default(now())
}

model GlobalNoticeRecipient {
  id            Int          @id @default(autoincrement())
  noticeId      Int
  institutionId Int
  readAt        DateTime?
  notice        GlobalNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  institution   Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([noticeId, institutionId])
}

model Permission {
  id              Int              @id @default(autoincrement())
  code            String           @unique @db.VarChar(120)
  name            String           @db.VarChar(140)
  module          String           @db.VarChar(80)
  description     String?          @db.Text
  rolePermissions RolePermission[]
  userPermissions UserPermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([module])
}

model RolePermission {
  id           Int          @id @default(autoincrement())
  role         PlatformRole
  permissionId Int
  permission   Permission   @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([role, permissionId])
  @@index([role])
}

model UserPermission {
  id           Int              @id @default(autoincrement())
  userId       Int
  permissionId Int
  effect       PermissionEffect @default(ALLOW)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission       @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([userId, permissionId])
  @@index([userId, effect])
}

model AccessAuditLog {
  id            Int      @id @default(autoincrement())
  actorUserId   Int?
  targetUserId  Int?
  institutionId Int?
  action        String   @db.VarChar(100)
  details       Json?
  ipAddress     String?  @db.VarChar(80)
  createdAt     DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([institutionId, createdAt])
}

model PlatformSetting {
  id                    Int      @id @default(autoincrement())
  companyName           String   @default("Enterprise ERP")
  legalName             String?
  supportEmail          String?
  billingEmail          String?
  supportPhone          String?
  secondaryPhone        String?
  websiteUrl            String?
  address               String?  @db.Text
  city                  String?
  country               String   @default("Pakistan")
  currency              String   @default("PKR")
  timezone              String   @default("Asia/Karachi")
  taxName               String?
  taxRate               Decimal  @default(0) @db.Decimal(8, 2)
  invoicePrefix         String   @default("ERP-INV")
  nextInvoiceNumber     Int      @default(1)
  invoiceDueDays        Int      @default(7)
  gracePeriodDays       Int      @default(7)
  autoSuspendEnabled    Boolean  @default(false)
  autoSuspendAfterDays  Int      @default(15)
  defaultBillingCycle   String   @default("MONTHLY")
  defaultMonthlyPrice   Decimal  @default(0) @db.Decimal(12, 2)
  defaultAnnualPrice    Decimal  @default(0) @db.Decimal(12, 2)
  defaultConcession     Decimal  @default(0) @db.Decimal(8, 2)
  subdomainBase         String   @default("your-erp.com")
  allowCustomDomains    Boolean  @default(true)
  maintenanceMode       Boolean  @default(false)
  maintenanceMessage    String?  @db.Text
  strongPasswords       Boolean  @default(true)
  sessionTimeoutMinutes Int      @default(60)
  maxLoginAttempts      Int      @default(5)
  auditRetentionDays    Int      @default(365)
  backupRetentionDays   Int      @default(30)
  dailyBackupEnabled    Boolean  @default(true)
  emailFromName         String   @default("Enterprise ERP")
  emailFromAddress      String?
  smtpHost              String?
  smtpPort              Int?
  smtpUsername          String?
  smtpSecure            Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model NotificationTemplate {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  subject   String
  body      String   @db.Text
  channel   String   @default("EMAIL")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformAuditEvent {
  id          Int      @id @default(autoincrement())
  userId      Int?
  action      String
  module      String
  entityType  String?
  entityId    String?
  description String?  @db.Text
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([module, createdAt])
  @@index([userId, createdAt])
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  PENDING
  ARCHIVED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Student {
  id               Int           @id @default(autoincrement())
  institutionId    Int
  studentId        String
  admissionNo      String
  rollNo           Int?
  firstName        String
  lastName         String
  gender           Gender
  dateOfBirth      DateTime?
  bFormNo          String?
  email            String?
  phone            String?
  className        String
  section          String?
  guardianName     String
  guardianPhone    String
  guardianRelation String?
  address          String?       @db.Text
  photoUrl         String?
  status           StudentStatus @default(ACTIVE)
  admissionDate    DateTime      @default(now())
  notes            String?       @db.Text
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  institution       Institution               @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  documents         StudentDocument[]
  guardians         StudentGuardian[]
  studentNotes      StudentNote[]
  history           StudentHistory[]
  attendanceRecords StudentAttendance[]
  subjectSelections StudentSubjectSelection[]
  examMarksEntries  ExamMarksEntry[]
  examResults       ExamResult[]

  @@unique([institutionId, studentId])
  @@unique([institutionId, admissionNo])
  @@index([institutionId, className, section])
  @@index([institutionId, status])
  @@index([institutionId, bFormNo])
}

model StudentDocument {
  id            Int      @id @default(autoincrement())
  studentId     Int
  institutionId Int
  documentType  String
  fileName      String
  fileUrl       String
  notes         String?  @db.Text
  uploadedAt    DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([institutionId, studentId])
  @@index([documentType])
}

model StudentGuardian {
  id             Int      @id @default(autoincrement())
  studentId      Int
  institutionId  Int
  name           String
  relation       String
  phone          String
  alternatePhone String?
  email          String?
  cnic           String?
  occupation     String?
  address        String?  @db.Text
  isPrimary      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([institutionId, studentId])
  @@index([phone])
}

model StudentNote {
  id            Int      @id @default(autoincrement())
  studentId     Int
  institutionId Int
  note          String   @db.Text
  createdById   Int?
  createdAt     DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([institutionId, studentId])
}

model StudentHistory {
  id            Int      @id @default(autoincrement())
  studentId     Int
  institutionId Int
  action        String
  previousData  Json?
  newData       Json?
  remarks       String?  @db.Text
  createdById   Int?
  createdAt     DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([institutionId, studentId, createdAt])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  LATE
}

enum AttendanceSessionStatus {
  DRAFT
  COMPLETED
}

model AttendanceSession {
  id             Int                     @id @default(autoincrement())
  institutionId  Int
  className      String
  section        String?
  attendanceDate DateTime
  status         AttendanceSessionStatus @default(DRAFT)
  markedById     Int?
  completedAt    DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  institution Institution         @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  records     StudentAttendance[]

  @@unique([institutionId, className, section, attendanceDate])
  @@index([institutionId, attendanceDate])
}

model StudentAttendance {
  id            Int              @id @default(autoincrement())
  institutionId Int
  sessionId     Int
  studentId     Int
  status        AttendanceStatus
  remarks       String?
  markedById    Int?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  institution Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  session     AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student     Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([institutionId, studentId])
}

enum StaffAttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  LATE
  HALF_DAY
}

model StaffAttendance {
  id              Int                   @id @default(autoincrement())
  institutionId   Int
  staffId         Int
  attendanceDate  DateTime
  status          StaffAttendanceStatus @default(PRESENT)
  checkIn         DateTime?
  checkOut        DateTime?
  workedMinutes   Int                   @default(0)
  lateMinutes     Int                   @default(0)
  overtimeMinutes Int                   @default(0)
  remarks         String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  staff       User        @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([institutionId, staffId, attendanceDate])
  @@index([institutionId, attendanceDate])
  @@index([institutionId, staffId])
}

enum ExamSchemeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ExamSubjectType {
  COMPULSORY
  ELECTIVE
  ALTERNATIVE
}

enum ExamResultStatus {
  DRAFT
  REVIEWED
  APPROVED
  PUBLISHED
}

model ExamBoardScheme {
  id               String           @id @default(cuid())
  institutionId    Int
  boardCode        String
  boardName        String
  name             String
  level            String
  groupName        String
  version          String
  certificateTotal Int
  passingPercent   Float            @default(33)
  status           ExamSchemeStatus @default(DRAFT)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  institution    Institution         @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  subjects       ExamSchemeSubject[]
  electiveGroups ExamElectiveGroup[]
  exams          ExamDefinition[]

  @@unique([institutionId, boardCode, version, level, groupName])
  @@index([institutionId, status])
}

model ExamSchemeSubject {
  id             String          @id @default(cuid())
  institutionId  Int
  schemeId       String
  code           String
  name           String
  subjectType    ExamSubjectType @default(COMPULSORY)
  theoryMarks    Int             @default(0)
  practicalMarks Int             @default(0)
  internalMarks  Int             @default(0)
  totalMarks     Int
  passingMarks   Int
  displayOrder   Int             @default(0)
  isActive       Boolean         @default(true)

  institution     Institution               @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  scheme          ExamBoardScheme           @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  electiveOptions ExamElectiveOption[]
  selections      StudentSubjectSelection[]
  examPapers      ExamSubjectPaper[]
  resultSubjects  ExamResultSubject[]

  @@unique([schemeId, code])
}

model ExamElectiveGroup {
  id            String  @id @default(cuid())
  institutionId Int
  schemeId      String
  name          String
  minSelections Int     @default(1)
  maxSelections Int     @default(1)
  isRequired    Boolean @default(true)

  institution Institution          @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  scheme      ExamBoardScheme      @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  options     ExamElectiveOption[]

  @@unique([schemeId, name])
}

model ExamElectiveOption {
  id              String @id @default(cuid())
  institutionId   Int
  electiveGroupId String
  schemeSubjectId String

  institution   Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  electiveGroup ExamElectiveGroup @relation(fields: [electiveGroupId], references: [id], onDelete: Cascade)
  schemeSubject ExamSchemeSubject @relation(fields: [schemeSubjectId], references: [id], onDelete: Cascade)

  @@unique([electiveGroupId, schemeSubjectId])
}

model StudentSubjectSelection {
  id              String   @id @default(cuid())
  institutionId   Int
  studentId       Int
  schemeSubjectId String
  academicSession String
  selectedAt      DateTime @default(now())

  institution   Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  student       Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schemeSubject ExamSchemeSubject @relation(fields: [schemeSubjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, schemeSubjectId, academicSession])
}

model ExamDefinition {
  id              String    @id @default(cuid())
  institutionId   Int
  schemeId        String
  academicSession String
  name            String
  term            String
  className       String
  section         String?
  resultDate      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  institution Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  scheme      ExamBoardScheme    @relation(fields: [schemeId], references: [id], onDelete: Restrict)
  subjects    ExamSubjectPaper[]
  results     ExamResult[]
}

model ExamSubjectPaper {
  id              String @id @default(cuid())
  institutionId   Int
  examId          String
  schemeSubjectId String
  theoryMax       Int    @default(0)
  practicalMax    Int    @default(0)
  internalMax     Int    @default(0)
  totalMarks      Int
  passingMarks    Int

  institution   Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  exam          ExamDefinition    @relation(fields: [examId], references: [id], onDelete: Cascade)
  schemeSubject ExamSchemeSubject @relation(fields: [schemeSubjectId], references: [id], onDelete: Restrict)
  marks         ExamMarksEntry[]

  @@unique([examId, schemeSubjectId])
}

model ExamMarksEntry {
  id                String  @id @default(cuid())
  institutionId     Int
  examSubjectId     String
  studentId         Int
  theoryObtained    Float   @default(0)
  practicalObtained Float   @default(0)
  internalObtained  Float   @default(0)
  totalObtained     Float   @default(0)
  isAbsent          Boolean @default(false)
  remarks           String?

  institution Institution      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  examSubject ExamSubjectPaper @relation(fields: [examSubjectId], references: [id], onDelete: Cascade)
  student     Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examSubjectId, studentId])
}

model ExamResult {
  id                 String           @id @default(cuid())
  institutionId      Int
  examId             String
  studentId          Int
  totalMarks         Float
  obtainedMarks      Float
  percentage         Float
  grade              String
  gpa                Float?
  resultStatus       String
  classPosition      Int?
  teacherComment     String?
  reviewerComment    String?
  recommendation     String?
  principalComment   String?
  resultCardPhotoUrl String?
  status             ExamResultStatus @default(DRAFT)
  generatedAt        DateTime         @default(now())

  institution Institution         @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  exam        ExamDefinition      @relation(fields: [examId], references: [id], onDelete: Cascade)
  student     Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjects    ExamResultSubject[]

  @@unique([examId, studentId])
}

model ExamResultSubject {
  id              String  @id @default(cuid())
  institutionId   Int
  resultId        String
  schemeSubjectId String
  totalMarks      Float
  obtainedMarks   Float
  passingMarks    Float
  percentage      Float
  grade           String
  resultStatus    String
  remarks         String?

  institution   Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  result        ExamResult        @relation(fields: [resultId], references: [id], onDelete: Cascade)
  schemeSubject ExamSchemeSubject @relation(fields: [schemeSubjectId], references: [id], onDelete: Restrict)

  @@unique([resultId, schemeSubjectId])
}
